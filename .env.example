SQLI_MAX_FORMS=3
SQLI_MAX_PARAMS_PER_FORM=4
SQLI_MAX_ERROR_PAYLOADS=4
SQLI_MAX_BOOLEAN_PAIRS=2
SQLI_MAX_TIME_PAYLOADS=1
LFI_MAX_PAGES=12
LFI_MAX_PARAMS=3
